extends ../layout

block content
  h2 Nueva Cuenta Corriente

  form(method="POST", action="/cuentas")

    label Cliente ID:
    input(type="number", name="idCliente", required)
    br
    br

    label Límite de Crédito:
    input(type="number", name="limiteCredito", value="150000", required)
    br
    br

    button(type="submit") Crear Cuenta

  a(href="/cuentas/vista") Volver